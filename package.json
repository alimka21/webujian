{
  "name": "webujian-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n FE,BE -c blue,green \"vite\" \"npm run dev --prefix server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.0",
    "zustand": "^5.0.13",
    "recharts": "^3.8.1",
    "lucide-react": "^0.546.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "date-fns": "^4.1.0",
    "sonner": "^2.0.7",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "tailwindcss": "^4.1.14",
    "@tailwindcss/vite": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1"
  }
}
