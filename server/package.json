    "prisma": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pdfkit": "^0.17.6",
    "typescript": "~5.8.2",
    "tsx": "^4.21.0"
