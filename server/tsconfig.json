{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["server.ts", "lib/**/*", "routes/**/*", "prisma/**/*", "types/**/*", "middleware.ts"],
  "exclude": ["node_modules", "dist"]
}
