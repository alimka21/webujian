# File: server/.env.production.example (untuk BACKEND)

# Backend environment variables
# Database MySQL Hostinger
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://u123_user:password@localhost:3306/u123_webujian"

# JWT secret - GENERATE: openssl rand -base64 48
# WAJIB ganti dengan random string minimal 32 karakter
JWT_SECRET="ganti_dengan_random_string_minimal_32_karakter"

# Server port (Hostinger override otomatis di production)
PORT=3001

# Environment
NODE_ENV=production

# Frontend URL untuk CORS - HARUS persis dengan domain frontend (TIDAK ADA SLASH DI AKHIR)
FRONTEND_URL="https://domain-anda.com"
